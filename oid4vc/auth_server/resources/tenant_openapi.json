    "/healthz": {
      "get": {
        "summary": "Health Check",
        "description": "Simple tenant server health check.",
        "operationId": "health_check_healthz_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/tenants/{uid}/healthz": {
      "get": {
        "summary": "Tenant Health Check",
        "description": "Tenant-scoped health check; DB connectivity is verified by dependency ping.",
        "operationId": "tenant_health_check_tenants__uid__healthz_get",
        "parameters": [
          {
            "name": "uid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Uid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
